<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/"
               xmlns:role="http://www.sitecore.net/xmlconfig/role/">
  <sitecore role:require="ContentManagement">
    <settings>
      <setting name="SitecoreJobs.DefaultCategory" value="SitecoreJobs" />
      <setting name="SitecoreJobs.DefaultSiteName" value="shell" />
      <setting name="SitecoreJobs.ProgressItemInterval" value="100" />
      <setting name="SitecoreJobs.ProgressTimeIntervalSeconds" value="2" />
      <setting name="SitecoreJobs.CompletedStatusRetentionMinutes" value="1440" />
      <setting name="SitecoreJobs.MaximumStoredWarnings" value="25" />
    </settings>
    <services>
      <configurator type="SitecoreJobs.Foundation.DependencyInjection.ServicesConfigurator, SitecoreJobs.Foundation" />
    </services>
  </sitecore>
</configuration>

<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
	<appSettings>
		<add key="aspnet:RequestQueueLimitPerSession" xdt:Locator="Match(key)" value="2147483647" xdt:Transform="SetAttributes(value)"/>
